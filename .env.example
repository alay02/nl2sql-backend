# Example environment file
# Copy this to .env and fill in with your actual values

# Database
DATABASE_URL=postgresql://your_user:your_password@your_host/your_db?sslmode=require

# OpenAI
OPENAI_API_KEY=sk-your-key-here

# API
API_DEBUG=false

# Local development identity (simulates a logged-in user until real auth exists)
APP_USER_ID=local-user
APP_USER_NAME=your name
APP_USER_ROLE=  # analyst, manager
